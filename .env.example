# Server
SERVER_PORT=11953
FRONTEND_PORT=8088

# ASR realtime
APP_VOICE_ASR_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
APP_VOICE_ASR_REALTIME_MODEL=qwen3-asr-flash-realtime
APP_VOICE_ASR_REALTIME_API_KEY=sk-xxx
# APP_VOICE_ASR_REALTIME_CONNECT_TIMEOUT_MS=10000
# APP_VOICE_ASR_REALTIME_MAX_CLIENT_EVENT_BYTES=1048576
# APP_VOICE_ASR_REALTIME_MAX_APPEND_AUDIO_CHARS=2097152
# APP_VOICE_ASR_REALTIME_MAX_PENDING_CLIENT_EVENTS=128
# APP_VOICE_ASR_REALTIME_MAX_PENDING_CLIENT_BYTES=1048576

# TTS local
APP_VOICE_TTS_DEFAULT_MODE=local
APP_VOICE_TTS_LOCAL_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
APP_VOICE_TTS_LOCAL_MODEL=qwen3-tts-instruct-flash-realtime
APP_VOICE_TTS_LOCAL_API_KEY=sk-xxx
APP_VOICE_TTS_DEFAULT_VOICE=Cherry
APP_VOICE_TTS_VOICES_JSON=[{"id":"Cherry","displayName":"Cherry","provider":"dashscope"},{"id":"Ethan","displayName":"Ethan","provider":"dashscope"},{"id":"Serena","displayName":"Serena","provider":"dashscope"}]
# APP_VOICE_TTS_LOCAL_MODE=server_commit
# APP_VOICE_TTS_LOCAL_RESPONSE_FORMAT=pcm
# APP_VOICE_TTS_LOCAL_SPEECH_RATE=1.2
# APP_VOICE_TTS_LOCAL_INSTRUCTIONS=
# APP_VOICE_TTS_LOCAL_SESSION_FINISHED_TIMEOUT_MS=120000
# APP_VOICE_TTS_LOCAL_LOG_SENT_CHUNK_ENABLED=false

# TTS runner
APP_VOICE_TTS_LLM_RUNNER_BASE_URL=http://localhost:8081
APP_VOICE_TTS_LLM_RUNNER_AGENT_KEY=demoModePlain
APP_VOICE_TTS_LLM_RUNNER_AUTHORIZATION_TOKEN=

# TTS runner optional
