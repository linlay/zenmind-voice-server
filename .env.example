# Service ports.
# SERVER_PORT: backend HTTP / WebSocket service port.
# FRONTEND_PORT: frontend debug console port exposed by docker compose.
# VOICE_SERVER_VERSION: release bundle image tag; used by compose.release.yml.
SERVER_PORT=11953
FRONTEND_PORT=11954
VOICE_SERVER_VERSION=latest

# ASR realtime provider settings.
# APP_VOICE_ASR_REALTIME_BASE_URL: third-party realtime ASR WebSocket endpoint.
# APP_VOICE_ASR_REALTIME_MODEL: ASR model name used for speech recognition.
# APP_VOICE_ASR_REALTIME_API_KEY: provider API key.
APP_VOICE_ASR_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
APP_VOICE_ASR_REALTIME_MODEL=qwen3-asr-flash-realtime
APP_VOICE_ASR_REALTIME_API_KEY=sk-xxx
# Optional ASR connection and payload limits. Keep defaults unless you need tuning.
# APP_VOICE_ASR_REALTIME_CONNECT_TIMEOUT_MS: timeout for connecting to provider, in ms. Default 10000.
# APP_VOICE_ASR_REALTIME_CONNECT_TIMEOUT_MS=10000
# APP_VOICE_ASR_REALTIME_MAX_CLIENT_EVENT_BYTES: max bytes for a single client event. Default 1048576.
# APP_VOICE_ASR_REALTIME_MAX_CLIENT_EVENT_BYTES=1048576
# APP_VOICE_ASR_REALTIME_MAX_APPEND_AUDIO_CHARS: max append-audio payload length. Default 2097152.
# APP_VOICE_ASR_REALTIME_MAX_APPEND_AUDIO_CHARS=2097152
# APP_VOICE_ASR_REALTIME_MAX_PENDING_CLIENT_EVENTS: max queued client events. Default 128.
# APP_VOICE_ASR_REALTIME_MAX_PENDING_CLIENT_EVENTS=128
# APP_VOICE_ASR_REALTIME_MAX_PENDING_CLIENT_BYTES: max queued client payload bytes. Default 1048576.
# APP_VOICE_ASR_REALTIME_MAX_PENDING_CLIENT_BYTES=1048576
# Browser-side voice activity gate. Enabled by default to suppress silence uploads.
# This is the main place to tune "ignore very light voice / background noise".
# Note: this is different from upstream turnDetection.threshold, which is currently hard-coded in service code.
# APP_VOICE_ASR_CLIENT_GATE_ENABLED: whether to enable local RMS gate. Default true.
# APP_VOICE_ASR_CLIENT_GATE_ENABLED=true
# APP_VOICE_ASR_CLIENT_GATE_RMS_THRESHOLD: RMS threshold; larger value means harder to open the gate. Default 0.008.
# Quick tuning reference: 0.008 = default, 0.012 = filter more soft voice, 0.015 = stricter.
# APP_VOICE_ASR_CLIENT_GATE_RMS_THRESHOLD=0.008
# APP_VOICE_ASR_CLIENT_GATE_OPEN_HOLD_MS: speech must stay above threshold for this long before opening. Default 120.
# APP_VOICE_ASR_CLIENT_GATE_OPEN_HOLD_MS=120
# APP_VOICE_ASR_CLIENT_GATE_CLOSE_HOLD_MS: speech must stay below threshold for this long before closing. Default 480.
# APP_VOICE_ASR_CLIENT_GATE_CLOSE_HOLD_MS=480
# APP_VOICE_ASR_CLIENT_GATE_PRE_ROLL_MS: keep this much pre-buffer audio before gate opens. Default 240.
# APP_VOICE_ASR_CLIENT_GATE_PRE_ROLL_MS=240
# APP_VOICE_ASR_WS_DETAILED_LOG_ENABLED: detailed ASR WebSocket logs. Default false.
# APP_VOICE_ASR_WS_DETAILED_LOG_ENABLED=false

# Local TTS provider settings.
# APP_VOICE_TTS_DEFAULT_MODE: default TTS mode when client does not send mode. Usually local; llm_qa uses runner.
APP_VOICE_TTS_DEFAULT_MODE=local
# APP_VOICE_TTS_LOCAL_ENDPOINT: third-party realtime TTS WebSocket endpoint.
APP_VOICE_TTS_LOCAL_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# APP_VOICE_TTS_LOCAL_MODEL: TTS model name.
APP_VOICE_TTS_LOCAL_MODEL=qwen3-tts-instruct-flash-realtime
# APP_VOICE_TTS_LOCAL_API_KEY: provider API key.
APP_VOICE_TTS_LOCAL_API_KEY=sk-xxx
# APP_VOICE_TTS_DEFAULT_VOICE: default voice ID, must exist in APP_VOICE_TTS_VOICES_JSON.
APP_VOICE_TTS_DEFAULT_VOICE=Cherry
# APP_VOICE_TTS_VOICES_JSON: voice list shown to client. id is protocol value, displayName is UI label.
APP_VOICE_TTS_VOICES_JSON=[{"id":"Cherry","displayName":"Cherry","provider":"dashscope"},{"id":"Ethan","displayName":"Ethan","provider":"dashscope"},{"id":"Serena","displayName":"Serena","provider":"dashscope"}]
# Optional local TTS advanced settings. Usually keep defaults.
# APP_VOICE_TTS_LOCAL_MODE: provider interaction mode. Default server_commit.
# APP_VOICE_TTS_LOCAL_MODE=server_commit
# APP_VOICE_TTS_LOCAL_RESPONSE_FORMAT: audio format returned by provider. Default pcm.
# APP_VOICE_TTS_LOCAL_RESPONSE_FORMAT=pcm
# APP_VOICE_TTS_LOCAL_SPEECH_RATE: speech speed multiplier; >1 faster, <1 slower. Default 1.2.
# APP_VOICE_TTS_LOCAL_SPEECH_RATE=1.2
# APP_VOICE_TTS_LOCAL_INSTRUCTIONS: extra prompt/instructions passed to TTS model for style control.
# APP_VOICE_TTS_LOCAL_INSTRUCTIONS=
# APP_VOICE_TTS_LOCAL_SESSION_FINISHED_TIMEOUT_MS: wait timeout after synthesis completes, in ms. Default 120000.
# APP_VOICE_TTS_LOCAL_SESSION_FINISHED_TIMEOUT_MS=120000
# APP_VOICE_TTS_LOCAL_LOG_SENT_CHUNK_ENABLED: whether to log outbound TTS audio chunk sends. Default false.
# APP_VOICE_TTS_LOCAL_LOG_SENT_CHUNK_ENABLED=false
# APP_VOICE_TTS_WS_DETAILED_LOG_ENABLED: detailed TTS WebSocket logs. Default false.
# APP_VOICE_TTS_WS_DETAILED_LOG_ENABLED=false

# LLM QA runner settings.
# Used when TTS mode is llm_qa or equivalent runner-based flow.
# APP_VOICE_TTS_LLM_RUNNER_BASE_URL: upstream runner HTTP base URL.
APP_VOICE_TTS_LLM_RUNNER_BASE_URL=http://localhost:8081
# APP_VOICE_TTS_LLM_RUNNER_AGENT_KEY: default agentKey fallback when client request does not specify one.
APP_VOICE_TTS_LLM_RUNNER_AGENT_KEY=demoModePlain
# APP_VOICE_TTS_LLM_RUNNER_AUTHORIZATION_TOKEN: bearer token or auth token for runner requests.
APP_VOICE_TTS_LLM_RUNNER_AUTHORIZATION_TOKEN=

# Optional runner timeout, in ms. Default 120000.
# APP_VOICE_TTS_LLM_RUNNER_REQUEST_TIMEOUT_MS=120000
