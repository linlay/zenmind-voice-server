# DashScope
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_TTS_API_KEY=sk-xxx

# TTS runner
APP_VOICE_TTS_LLM_RUNNER_BASE_URL=http://localhost:8081
APP_VOICE_TTS_LLM_RUNNER_AGENT_KEY=demoModePlain
APP_VOICE_TTS_LLM_RUNNER_AUTHORIZATION_TOKEN=

# Server
SERVER_PORT=11953

# ASR realtime
# DASHSCOPE_REALTIME_BASE_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# DASHSCOPE_REALTIME_MODEL=qwen3-asr-flash-realtime
# DASHSCOPE_REALTIME_CONNECT_TIMEOUT_MS=10000
# DASHSCOPE_REALTIME_MAX_CLIENT_EVENT_BYTES=1048576
# DASHSCOPE_REALTIME_MAX_APPEND_AUDIO_CHARS=2097152
# DASHSCOPE_REALTIME_MAX_PENDING_CLIENT_EVENTS=128
# DASHSCOPE_REALTIME_MAX_PENDING_CLIENT_BYTES=1048576

# TTS local
# APP_VOICE_TTS_DEFAULT_MODE=local
# DASHSCOPE_TTS_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
# DASHSCOPE_TTS_MODEL=qwen3-tts-instruct-flash-realtime
# DASHSCOPE_TTS_MODE=server_commit
# DASHSCOPE_TTS_RESPONSE_FORMAT=pcm
# DASHSCOPE_TTS_SPEECH_RATE=1.2
# DASHSCOPE_TTS_INSTRUCTIONS=
# DASHSCOPE_TTS_SESSION_FINISHED_TIMEOUT_MS=120000
# DASHSCOPE_TTS_LOG_SENT_CHUNK_ENABLED=false
# DASHSCOPE_TTS_DEFAULT_VOICE=Cherry

# TTS runner optional
